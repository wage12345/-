<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>学生列表 - 学生信息管理系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <span class="navbar-brand">学生信息管理系统</span>
      <div class="d-flex align-items-center gap-3">
        <span class="text-muted">当前用户：<%= user.username %></span>
        <form action="/logout" method="POST">
          <button class="btn btn-outline-secondary btn-sm" type="submit">退出登录</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">学生信息列表</h4>
      <a href="/students/new" class="btn btn-primary">新增学生</a>
    </div>

    <form class="row g-2 mb-3" method="GET" action="/students">
      <div class="col-md-10">
        <input
          type="text"
          name="keyword"
          class="form-control"
          placeholder="请输入学号、姓名或班级"
          value="<%= keyword %>"
        />
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-outline-primary" type="submit">查询</button>
      </div>
    </form>

    <div class="card shadow-sm">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>学号</th>
                <th>姓名</th>
                <th>性别</th>
                <th>班级</th>
                <th>电话</th>
                <th>创建时间</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              <% if (students.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted">暂无数据</td>
                </tr>
              <% } %>

              <% students.forEach(function(student) { %>
                <tr>
                  <td><%= student.student_no %></td>
                  <td><%= student.name %></td>
                  <td><%= student.gender %></td>
                  <td><%= student.class_name %></td>
                  <td><%= student.phone || '-' %></td>
                  <td><%= student.created_at ? new Date(student.created_at).toLocaleString() : '-' %></td>
                  <td>
                    <div class="table-actions">
                      <a class="btn btn-sm btn-outline-primary" href="/students/<%= student.id %>/edit">编辑</a>
                      <form action="/students/<%= student.id %>/delete" method="POST" onsubmit="return confirm('确定删除该学生吗？');">
                        <button class="btn btn-sm btn-outline-danger" type="submit">删除</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</body>
</html>